# Happy Cake — environment variables (placeholders only; never commit real values)

# ─── Sandbox MCP ───────────────────────────────────────────────────────────────
# Get this from your team dashboard at steppebusinessclub.com.
# Format: sbc_team_<32 hex chars>
TEAM_TOKEN=sbc_team_REPLACE_WITH_YOURS
MCP_BASE_URL=https://www.steppebusinessclub.com/api/mcp

# ─── Telegram bots (one token per agent) ───────────────────────────────────────
# Create each bot via @BotFather, paste the token here.
TELEGRAM_CONCIERGE_BOT_TOKEN=
TELEGRAM_ORDERS_BOT_TOKEN=
TELEGRAM_MARKETING_BOT_TOKEN=
TELEGRAM_OWNER_BOT_TOKEN=

# Owner's Telegram numeric user id (use @userinfobot to find).
# Only this user (and any in TELEGRAM_OPERATOR_USER_IDS, comma-separated) can run owner commands.
TELEGRAM_OWNER_USER_ID=
TELEGRAM_OPERATOR_USER_IDS=

# ─── Webhook tunnel ────────────────────────────────────────────────────────────
# After `make start` prints the cloudflared / ngrok URL, set this and run
# `make register-webhooks` to register it with the simulator.
TUNNEL_PUBLIC_URL=https://<your-tunnel>.trycloudflare.com

# Per-channel HMAC secrets (sandbox provides these; in production they come
# from Meta / WhatsApp Business / Telegram).
WHATSAPP_WEBHOOK_SECRET=
INSTAGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_SECRET=

# ─── Datastores ────────────────────────────────────────────────────────────────
# Defaults match the docker-compose.yml services; change only for managed setups.
POSTGRES_DSN=postgresql+asyncpg://hc:hc@localhost:5432/happycake
REDIS_URL=redis://localhost:6379/0

# ─── Website ───────────────────────────────────────────────────────────────────
SITE_PUBLIC_URL=http://localhost:3000
SITE_SUPPORT_EMAIL=hello@happycake.us
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ASSISTANT_API=http://localhost:8080/api/chat

# ─── Claude Code ───────────────────────────────────────────────────────────────
# Path to the `claude` binary if not on PATH.
CLAUDE_BIN=claude
# Per-invocation guardrails.
CLAUDE_MAX_TURNS=8
CLAUDE_TIMEOUT_S=60
CLAUDE_MODEL=claude-opus-4-7

# ─── Trust tiers ───────────────────────────────────────────────────────────────
# Order AOV (in USD cents) above which Tier-B becomes Tier-C (always blocking).
TIER_B_MAX_AOV_CENTS=8000
# Grace window in seconds before Tier-B orders auto-confirm if owner doesn't act.
TIER_B_GRACE_SECONDS=300

# ─── Marketing ─────────────────────────────────────────────────────────────────
MARKETING_MONTHLY_BUDGET_CENTS=50000   # $500
MARKETING_BANDIT_EPSILON=0.2
MARKETING_DAILY_RUN_HOUR_LOCAL=8       # 08:30 trigger after owner briefing
TIMEZONE=America/Chicago

# ─── Internal evidence endpoint ────────────────────────────────────────────────
# Required by /internal/audit; pick any random long string.
INTERNAL_AUDIT_TOKEN=

# ─── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_REDACT_BODIES=true
SENTRY_DSN=

# ─── Rate limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_PER_HANDLE_PER_MIN=30
RATE_LIMIT_GLOBAL_PER_MIN=1000

# ─── Production-only (leave blank for hackathon) ───────────────────────────────
# When the system goes live, these replace the sandbox MCP. See PRODUCTION_HANDOFF.md.
WHATSAPP_CLOUD_API_TOKEN=
META_GRAPH_API_TOKEN=
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
GOOGLE_BUSINESS_API_TOKEN=
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
