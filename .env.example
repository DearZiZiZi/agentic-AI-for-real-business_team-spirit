# Happy Cake — environment variables (placeholders only; never commit real values)

# ─── Required for demo ────────────────────────────────────────────────────────

# Sandbox MCP (from team dashboard at steppebusinessclub.com)
TEAM_TOKEN=sbc_team_REPLACE_WITH_YOURS
MCP_BASE_URL=https://www.steppebusinessclub.com/api/mcp

# Telegram owner bot (one bot, one agent)
TELEGRAM_OWNER_BOT_TOKEN=
TELEGRAM_OWNER_USER_ID=

# Webhook tunnel (printed by `make start`; set after first run)
TUNNEL_PUBLIC_URL=

# Random string; gates /internal/audit
INTERNAL_AUDIT_TOKEN=

# CORS Security
ALLOWED_ORIGINS=https://happycake.com,https://app.happycake.com

# ─── Defaults (rarely changed) ────────────────────────────────────────────────

CLAUDE_BIN=claude
CLAUDE_TIMEOUT_S=60

# Tier-B rules
TIER_B_MAX_AOV_CENTS=8000
TIER_B_GRACE_SECONDS=300

# Marketing
MARKETING_MONTHLY_BUDGET_CENTS=50000
TIMEZONE=America/Chicago

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ASSISTANT_API=http://localhost:8080/api/chat

# ─── Production-only (leave blank for hackathon) ──────────────────────────────
# See PRODUCTION_HANDOFF.md for the swap list.
WHATSAPP_CLOUD_API_TOKEN=
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
TWILIO_SID=
TWILIO_AUTH_TOKEN=
